# Cyran Labs Engine — Variables d'environnement

# --- Server ---
PORT=3800
BASE_URL=https://demo-wa.cyran.ai
NODE_ENV=development

# --- Database (laisser vide pour fallback SQLite local) ---
DATABASE_URL=postgres://user:pass@localhost:5432/cyran_labs

# --- Master encryption key (pour credentials chiffrées en DB) ---
# Générer avec : openssl rand -hex 32
MASTER_ENCRYPTION_KEY=

# --- LLM par défaut (overridable par tenant) ---
ANTHROPIC_API_KEY=

OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# --- Audio (Whisper via Groq) ---
GROQ_API_KEY=

# --- Admin ---
ADMIN_PHONES=
DASHBOARD_API_KEY=

# --- Logs ---
LOG_LEVEL=info

# --- Transport CM.com (BSP) ---
CM_PRODUCT_TOKEN=
CM_FROM_NUMBER=
CM_SERVICE_URL=https://gw.cmtelecom.com/v1.0/message

# --- Transport Meta Cloud API (officiel) ---
# Récupérer depuis Meta Business Manager → WhatsApp → Configuration API
META_PHONE_NUMBER_ID=
META_WABA_ID=
WA_PHONE_NUMBER=
META_ACCESS_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
