# Cyran Labs Engine — Variables d'environnement

# --- Server ---
PORT=3800
BASE_URL=https://demo-wa.cyran.ai
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgres://user:pass@localhost:5432/cyran_labs

# --- Master encryption key (pour credentials chiffrées en DB) ---
# Générer avec : openssl rand -hex 32
MASTER_ENCRYPTION_KEY=

# --- LLM par défaut (overridable par tenant) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# --- Audio (Whisper via Groq) ---
GROQ_API_KEY=

# --- Admin ---
ADMIN_PHONES=33761848975
DASHBOARD_API_KEY=

# --- Logs ---
LOG_LEVEL=info
